# CometChat configuration
#
# Copy this file to .env (do NOT commit your real .env file).
# Vite only exposes variables prefixed with VITE_ to the browser.

VITE_COMETCHAT_APP_ID="your_app_id_here"
VITE_COMETCHAT_AUTH_KEY="your_auth_key_here"
VITE_COMETCHAT_REGION="your_region_here" # e.g. "us" or "eu" depending on your CometChat setup

